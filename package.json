{
  "name": "onelog",
  "version": "1.0.0",
  "description": "A lightweight, open-source daily diary for working professionals",
  "main": "src/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "node scripts/wait-for-vite.js && electron .",
    "dev": "concurrently -n renderer,electron \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && npx electron-rebuild -f -w better-sqlite3 && electron-builder --win",
    "build:win": "npm run build:renderer && npx electron-rebuild -f -w better-sqlite3 && electron-builder --win",
    "build:mac": "npm run build:renderer && npx electron-rebuild -f -w better-sqlite3 && electron-builder --mac",
    "build:linux": "npm run build:renderer && npx electron-rebuild -f -w better-sqlite3 && electron-builder --linux",
    "build:all": "npm run build:renderer && npx electron-rebuild -f -w better-sqlite3 && electron-builder --win --mac --linux",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.onelog.app",
    "productName": "OneLog",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main/**/*",
      "dist/renderer/**/*"
    ],
    "extraResources": [],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": null,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OneLog"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-underline": "^3.19.0",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "better-sqlite3": "^12.6.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.4.0",
    "electron-builder": "^26.7.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
